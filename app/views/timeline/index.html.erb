<main class="mx-auto flex max-w-7xl flex-col gap-8 px-4 py-8 sm:px-6 lg:px-8">
  <header class="flex flex-col gap-4 border-b border-slate-200 pb-6 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <h1 class="text-3xl font-semibold text-slate-950">Timeline</h1>
      <p class="mt-2 text-sm text-slate-600"><%= pluralize(@events.count, "event") %> extracted from uploaded documents.</p>
    </div>

    <%= link_to "Back to documents", documents_path, class: "text-sm font-medium text-slate-600 hover:text-slate-950" %>
  </header>

  <% if @events.any? %>
    <section class="space-y-10">
      <% @dated_events_by_year.each do |year, events| %>
        <div class="grid gap-5 lg:grid-cols-[7rem_minmax(0,1fr)]">
          <div>
            <p class="text-2xl font-semibold text-slate-950"><%= year %></p>
            <p class="mt-1 text-xs font-medium uppercase text-slate-500"><%= pluralize(events.count, "event") %></p>
          </div>

          <div class="relative space-y-5 border-l border-slate-300 pl-6">
            <% events.each do |event| %>
              <% chunk = event.document_chunk %>
              <article class="relative rounded-lg border border-slate-200 bg-white shadow-sm">
                <span class="absolute -left-[31px] top-5 size-3 rounded-full border-2 border-white bg-emerald-700 shadow-sm"></span>

                <div class="grid gap-4 px-5 py-4 lg:grid-cols-[10rem_minmax(0,1fr)]">
                  <div>
                    <% if event.date_range? %>
                      <p class="text-sm font-semibold text-slate-950">
                        <%= l event.started_on, format: :long %>
                      </p>
                      <p class="mt-1 text-sm text-slate-600">
                        to <%= l event.ended_on, format: :long %>
                      </p>
                    <% else %>
                      <p class="text-sm font-semibold text-slate-950"><%= l event.sort_date, format: :long %></p>
                    <% end %>

                    <p class="mt-3 inline-flex rounded-md bg-emerald-50 px-2 py-1 text-xs font-semibold uppercase text-emerald-800">
                      <%= event.event_type.humanize %>
                    </p>
                    <p class="mt-2 text-xs text-slate-500">
                      <%= event.date_source.humanize %> &middot; <%= event.date_precision.humanize %>
                    </p>
                  </div>

                  <div class="min-w-0">
                    <h2 class="text-base font-semibold text-slate-950"><%= event.title %></h2>
                    <p class="mt-2 text-sm leading-6 text-slate-700"><%= event.description %></p>

                    <div class="mt-4 flex flex-wrap gap-2 text-xs font-medium text-slate-600">
                      <%= link_to event.document.title, document_path(event.document), class: "rounded-md bg-slate-100 px-2.5 py-1 hover:bg-slate-200" %>
                      <span class="rounded-md bg-slate-100 px-2.5 py-1">Page <%= event.document_page.page_number %></span>
                      <span class="rounded-md bg-slate-100 px-2.5 py-1">Chunk <%= chunk.chunk_index %></span>
                      <span class="rounded-md bg-slate-100 px-2.5 py-1"><%= chunk.label.humanize %></span>
                    </div>

                    <details class="mt-4 border-t border-slate-100 pt-3">
                      <summary class="cursor-pointer text-sm font-medium text-slate-600 hover:text-slate-950">Source evidence</summary>
                      <blockquote class="mt-3 border-l-4 border-slate-200 pl-3 text-sm leading-6 text-slate-600">
                        <%= event.source_quote %>
                      </blockquote>
                    </details>
                  </div>
                </div>
              </article>
            <% end %>
          </div>
        </div>
      <% end %>

      <% if @undated_events.any? %>
        <section class="border-t border-slate-200 pt-8">
          <div class="mb-5">
            <h2 class="text-xl font-semibold text-slate-950">Undated Events</h2>
            <p class="mt-1 text-sm text-slate-600">Useful timeline evidence without a reliable date.</p>
          </div>

          <div class="grid gap-4 md:grid-cols-2">
            <% @undated_events.each do |event| %>
              <% chunk = event.document_chunk %>
              <article class="rounded-lg border border-slate-200 bg-white px-5 py-4 shadow-sm">
                <p class="inline-flex rounded-md bg-slate-100 px-2 py-1 text-xs font-semibold uppercase text-slate-700">
                  <%= event.event_type.humanize %>
                </p>
                <h3 class="mt-3 text-base font-semibold text-slate-950"><%= event.title %></h3>
                <p class="mt-2 text-sm leading-6 text-slate-700"><%= event.description %></p>

                <div class="mt-4 flex flex-wrap gap-2 text-xs font-medium text-slate-600">
                  <%= link_to event.document.title, document_path(event.document), class: "rounded-md bg-slate-100 px-2.5 py-1 hover:bg-slate-200" %>
                  <span class="rounded-md bg-slate-100 px-2.5 py-1">Page <%= event.document_page.page_number %></span>
                  <span class="rounded-md bg-slate-100 px-2.5 py-1">Chunk <%= chunk.chunk_index %></span>
                  <span class="rounded-md bg-slate-100 px-2.5 py-1"><%= chunk.label.humanize %></span>
                </div>
              </article>
            <% end %>
          </div>
        </section>
      <% end %>
    </section>
  <% else %>
    <section class="rounded-lg border border-dashed border-slate-300 bg-white px-4 py-12 text-center">
      <h2 class="text-base font-semibold text-slate-950">No timeline events yet</h2>
      <p class="mt-1 text-sm text-slate-500">Upload and process documents to extract timeline events.</p>
    </section>
  <% end %>
</main>
