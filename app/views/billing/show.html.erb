<% content_for :title, "Billing | PaperBridge" %>

<%= app_shell(active: :billing) do %>
  <% active = current_account.subscription_active? %>
  <% status_label =
    if @billing_subscription.nil?
      "Not started"
    elsif @billing_subscription.trialing?
      "Trial active"
    elsif @billing_subscription.active?
      "Active"
    elsif @billing_subscription.past_due? || @billing_subscription.unpaid?
      "Payment needed"
    elsif @billing_subscription.canceled?
      "Canceled"
    else
      "Not active"
    end %>

  <div class="space-y-8 pb-10" data-testid="billing-page">
    <header class="flex flex-col gap-4 pt-2 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="mb-1 text-xs font-medium uppercase tracking-widest text-accent">Account Billing</p>
        <h1 class="text-3xl font-bold tracking-tight text-primary">Subscription</h1>
        <p class="mt-1.5 text-sm text-muted-foreground">Manage paid access for <%= current_account.name %>.</p>
      </div>
      <% if @can_manage_billing && @portal_ready %>
        <%= button_to billing_portal_session_path,
            method: :post,
            form: { data: { turbo: false } },
            class: "inline-flex h-10 items-center justify-center rounded-full bg-primary px-5 text-sm font-medium text-white shadow-sm transition-all duration-200 hover:bg-primary/90",
            data: { testid: "manage-subscription-button" } do %>
          <%= pb_icon("shield", class_name: "mr-1.5 h-4 w-4") %>
          Manage Subscription
        <% end %>
      <% end %>
    </header>

    <section class="rounded-2xl border border-border/50 bg-white p-6 shadow-sm">
      <div class="flex flex-col gap-5 md:flex-row md:items-start md:justify-between">
        <div>
          <div class="flex items-center gap-2.5">
            <span class="inline-flex h-9 w-9 items-center justify-center rounded-xl <%= active ? "bg-emerald-50 text-emerald-700" : "bg-amber-50 text-amber-700" %>">
              <%= pb_icon(active ? "check-circle" : "alert-circle", class_name: "h-4 w-4") %>
            </span>
            <div>
              <h2 class="text-base font-semibold text-foreground" data-testid="billing-status">
                <%= active ? "Subscription active" : "Subscription required" %>
              </h2>
              <p class="mt-0.5 text-sm text-muted-foreground">
                Current status:
                <span class="font-medium text-foreground"><%= status_label %></span>
              </p>
            </div>
          </div>

          <% if @billing_subscription&.current_period_end.present? %>
            <p class="mt-4 text-sm text-muted-foreground">
              Current period ends <%= l(@billing_subscription.current_period_end, format: :long) %>.
            </p>
          <% end %>

          <% if @billing_subscription&.cancel_at_period_end? %>
            <p class="mt-3 inline-flex rounded-full bg-amber-50 px-3 py-1 text-xs font-medium text-amber-800">
              Cancels at period end
            </p>
          <% end %>
        </div>

        <div class="w-full md:w-auto">
          <% if @can_manage_billing && !current_account.subscription_active? %>
            <% if @checkout_ready %>
              <%= button_to billing_checkout_session_path,
                  method: :post,
                  form: { data: { turbo: false } },
                  class: "flex h-10 w-full items-center justify-center rounded-full bg-accent px-5 text-sm font-medium text-accent-foreground shadow-sm transition-all duration-200 hover:bg-accent/80 md:w-auto",
                  data: { testid: "subscribe-button" } do %>
                <%= pb_icon("arrow-right", class_name: "mr-1.5 h-4 w-4") %>
                Subscribe
              <% end %>
            <% else %>
              <div class="rounded-xl border border-amber-200 bg-amber-50 p-4 text-sm text-amber-900" data-testid="billing-setup-required">
                Online subscription setup is not available yet.
              </div>
            <% end %>
          <% elsif !@can_manage_billing %>
            <div class="rounded-xl border border-border bg-muted/40 p-4 text-sm text-muted-foreground">
              Ask an account admin to manage this subscription.
            </div>
          <% end %>
        </div>
      </div>
    </section>
  </div>
<% end %>
