<%= form_with model: [@dependent, care_team_membership], class: "space-y-5 rounded-2xl border border-border/50 bg-white p-6 shadow-sm" do |form| %>
  <% if care_team_membership.errors.any? %>
    <div class="rounded-xl border border-red-200 bg-red-50 p-4 text-red-900" role="alert">
      <h2 class="text-sm font-semibold"><%= pluralize(care_team_membership.errors.count, "error") %> prevented this care team member from saving</h2>
      <ul class="mt-2 list-disc space-y-1 pl-5 text-sm">
        <% care_team_membership.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid gap-4 sm:grid-cols-2">
    <div>
      <%= form.label :name, "Full name", class: "block text-sm font-medium text-slate-700" %>
      <%= form.text_field :name, class: "mt-2 block w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm text-slate-950 shadow-sm outline-none focus:border-primary focus:ring-2 focus:ring-primary/10" %>
    </div>

    <div>
      <%= form.label :email, class: "block text-sm font-medium text-slate-700" %>
      <%= form.email_field :email, class: "mt-2 block w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm text-slate-950 shadow-sm outline-none focus:border-primary focus:ring-2 focus:ring-primary/10" %>
    </div>
  </div>

  <div class="grid gap-4 sm:grid-cols-2">
    <div>
      <%= form.label :role, class: "block text-sm font-medium text-slate-700" %>
      <%= form.select :role, CareTeamMembership.roles.keys.map { |role| [role.humanize, role] }, {}, class: "mt-2 block w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm text-slate-950 shadow-sm outline-none focus:border-primary focus:ring-2 focus:ring-primary/10" %>
    </div>

    <div>
      <%= form.label :status, class: "block text-sm font-medium text-slate-700" %>
      <%= form.select :status, CareTeamMembership.statuses.keys.map { |status| [status.humanize, status] }, {}, class: "mt-2 block w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm text-slate-950 shadow-sm outline-none focus:border-primary focus:ring-2 focus:ring-primary/10" %>
    </div>
  </div>

  <fieldset class="rounded-2xl border border-border/50 bg-muted/40 p-4">
    <legend class="px-1 text-xs font-semibold uppercase tracking-wider text-muted-foreground">Document Access</legend>
    <p class="mt-1 text-xs text-muted-foreground">Choose the document categories this care team member can view. Access is read-only.</p>
    <div class="mt-4 grid gap-3 sm:grid-cols-2">
      <% CareTeamMembership::DOCUMENT_CATEGORY_PERMISSIONS.each do |category| %>
        <label class="flex items-center justify-between rounded-xl border border-border/60 bg-white px-4 py-3 text-sm">
          <span class="font-medium text-foreground"><%= category.humanize %></span>
          <%= check_box_tag "care_team_membership[permissions][#{category}]", "1", care_team_membership.permissions.fetch(category, false), class: "h-4 w-4 rounded border-border text-primary focus:ring-primary" %>
        </label>
      <% end %>
    </div>
  </fieldset>

  <div class="flex items-center justify-end gap-3 border-t border-border/50 pt-5">
    <%= link_to "Cancel", dependent_care_team_memberships_path(@dependent), class: "rounded-full px-4 py-2 text-sm font-medium text-muted-foreground hover:bg-muted" %>
    <%= form.submit class: "rounded-full bg-primary px-5 py-2 text-sm font-medium text-white shadow-sm hover:bg-primary/90" %>
  </div>
<% end %>
