<% content_for :title, "Care Team | PaperBridge" %>

<%= app_shell(active: :care_team, dependent: @dependent) do %>
  <div class="space-y-8">
    <header class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <%= link_to @dependent, class: "inline-flex items-center text-sm font-medium text-muted-foreground hover:text-foreground" do %>
          <span aria-hidden="true" class="mr-2">&larr;</span>
          Back to <%= @dependent.name %>
        <% end %>
        <p class="mt-6 text-xs font-medium uppercase tracking-widest text-accent">Support Network</p>
        <h1 class="mt-1 text-2xl font-bold tracking-tight text-primary md:text-3xl">Care Team</h1>
        <p class="mt-1.5 text-sm text-muted-foreground">Manage who can access <%= @dependent.name %>'s records.</p>
      </div>
      <%= link_to new_dependent_care_team_membership_path(@dependent), class: "inline-flex h-10 items-center justify-center rounded-full bg-accent px-5 text-sm font-medium text-accent-foreground shadow-sm hover:bg-accent/80", data: { testid: "care-team-invite-link" } do %>
        <%= pb_icon("plus", class_name: "mr-1.5 h-4 w-4") %>
        Invite Member
      <% end %>
    </header>

    <% if @care_team_memberships.any? %>
      <section class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
        <% @care_team_memberships.each do |membership| %>
          <article class="rounded-2xl border border-border/60 bg-white p-6 shadow-sm transition-all hover:border-primary/20 hover:shadow-md" data-testid="care-team-member-<%= membership.id %>">
            <div class="mb-4 flex items-start justify-between gap-3">
              <div class="flex min-w-0 items-center gap-3">
                <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-primary/10 text-sm font-bold text-primary">
                  <%= membership.name.split.map { |word| word.first }.join.first(2).upcase %>
                </div>
                <div class="min-w-0">
                  <p class="truncate text-sm font-bold text-foreground"><%= membership.name %></p>
                  <p class="truncate text-xs text-muted-foreground"><%= membership.email %></p>
                </div>
              </div>
              <span class="rounded-full bg-muted px-2 py-0.5 text-[10px] font-medium capitalize text-muted-foreground"><%= membership.status.humanize %></span>
            </div>

            <div class="mb-4 flex flex-wrap gap-2">
              <span class="rounded-full bg-primary/10 px-2.5 py-1 text-[10px] font-medium capitalize text-primary"><%= membership.role.humanize %></span>
              <% membership.allowed_document_categories.each do |category| %>
                <span class="rounded-full bg-muted px-2.5 py-1 text-[10px] font-medium text-muted-foreground"><%= category.humanize %></span>
              <% end %>
            </div>

            <div class="flex items-center justify-end gap-2 border-t border-border/50 pt-4">
              <%= link_to "Edit", edit_dependent_care_team_membership_path(@dependent, membership), class: "rounded-full px-3 py-1.5 text-xs font-medium text-primary hover:bg-primary/5" %>
              <%= button_to "Remove", dependent_care_team_membership_path(@dependent, membership), method: :delete, class: "rounded-full px-3 py-1.5 text-xs font-medium text-red-600 hover:bg-red-50" %>
            </div>
          </article>
        <% end %>
      </section>
    <% else %>
      <section class="rounded-2xl border border-border/60 bg-white p-8 text-center shadow-sm">
        <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-2xl border border-primary/10 bg-primary/5">
          <%= pb_icon("users", class_name: "h-5 w-5 text-primary/60") %>
        </div>
        <h2 class="text-base font-semibold text-foreground">Build the care team</h2>
        <p class="mx-auto mt-2 max-w-lg text-sm leading-relaxed text-muted-foreground">Invite teachers, therapists, doctors, advocates, or family members and choose which document categories they can access.</p>
        <%= link_to "Invite First Member", new_dependent_care_team_membership_path(@dependent), class: "mt-5 inline-flex rounded-full bg-primary px-5 py-2 text-xs font-medium text-white hover:bg-primary/90" %>
      </section>
    <% end %>
  </div>
<% end %>
