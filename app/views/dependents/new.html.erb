<% content_for :title, "New User | PaperBridge" %>

<%= app_shell(active: :dependents) do %>
  <div class="mx-auto max-w-2xl space-y-6">
    <header>
      <%= link_to dependents_path, class: "inline-flex items-center text-sm font-medium text-muted-foreground hover:text-foreground" do %>
        <span aria-hidden="true" class="mr-2">&larr;</span>
        Back to users
      <% end %>
      <h1 class="mt-6 text-2xl font-bold tracking-tight text-foreground md:text-3xl">Add User</h1>
      <p class="mt-1 text-sm text-muted-foreground">Create the record owner for documents and care team access.</p>
    </header>

    <%= render "form", dependent: @dependent %>
  </div>
<% end %>
