<%= form_with model: dependent, class: "space-y-5 rounded-2xl border border-border/50 bg-white p-6 shadow-sm" do |form| %>
  <% if dependent.errors.any? %>
    <div class="rounded-xl border border-red-200 bg-red-50 p-4 text-red-900" role="alert">
      <h2 class="text-sm font-semibold"><%= pluralize(dependent.errors.count, "error") %> prevented this dependent from saving</h2>
      <ul class="mt-2 list-disc space-y-1 pl-5 text-sm">
        <% dependent.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, class: "block text-sm font-medium text-slate-700" %>
    <%= form.text_field :name, autofocus: true, class: "mt-2 block w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm text-slate-950 shadow-sm outline-none focus:border-primary focus:ring-2 focus:ring-primary/10" %>
  </div>

  <div class="grid gap-4 sm:grid-cols-2">
    <div>
      <%= form.label :grade, class: "block text-sm font-medium text-slate-700" %>
      <%= form.text_field :grade, class: "mt-2 block w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm text-slate-950 shadow-sm outline-none focus:border-primary focus:ring-2 focus:ring-primary/10" %>
    </div>

    <div>
      <%= form.label :date_of_birth, class: "block text-sm font-medium text-slate-700" %>
      <%= form.date_field :date_of_birth, class: "mt-2 block w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm text-slate-950 shadow-sm outline-none focus:border-primary focus:ring-2 focus:ring-primary/10" %>
    </div>
  </div>

  <div>
    <%= form.label :school, class: "block text-sm font-medium text-slate-700" %>
    <%= form.text_field :school, class: "mt-2 block w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm text-slate-950 shadow-sm outline-none focus:border-primary focus:ring-2 focus:ring-primary/10" %>
  </div>

  <div>
    <%= form.label :notes, class: "block text-sm font-medium text-slate-700" %>
    <%= form.text_area :notes, rows: 4, class: "mt-2 block w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm text-slate-950 shadow-sm outline-none focus:border-primary focus:ring-2 focus:ring-primary/10" %>
  </div>

  <div class="flex items-center justify-end gap-3 border-t border-border/50 pt-5">
    <%= link_to "Cancel", dependents_path, class: "rounded-full px-4 py-2 text-sm font-medium text-muted-foreground hover:bg-muted" %>
    <%= form.submit class: "rounded-full bg-primary px-5 py-2 text-sm font-medium text-white shadow-sm hover:bg-primary/90" %>
  </div>
<% end %>
