<main class="mx-auto grid max-w-7xl gap-8 px-4 py-8 sm:px-6 lg:grid-cols-[minmax(0,1fr)_24rem] lg:px-8">
  <section class="flex flex-col gap-6">
    <header class="border-b border-slate-200 pb-6">
      <%= link_to root_path, class: "inline-flex items-center text-sm font-medium text-slate-600 hover:text-slate-950" do %>
        <span aria-hidden="true" class="mr-2">&larr;</span>
        PaperBridge
      <% end %>

      <div class="mt-8 max-w-3xl">
        <p class="inline-flex rounded-md bg-emerald-50 px-2.5 py-1 text-xs font-semibold uppercase text-emerald-800">New workspace</p>
        <h1 class="mt-4 text-3xl font-semibold text-slate-950">Create account</h1>
        <p class="mt-3 text-base leading-7 text-slate-600">
          Start a PaperBridge workspace for uploading records, organizing source evidence, and building reviewable timelines.
        </p>
      </div>
    </header>

    <div class="grid gap-4 md:grid-cols-2">
      <article class="rounded-lg border border-slate-200 bg-white px-5 py-4 shadow-sm">
        <p class="inline-flex rounded-md bg-slate-100 px-2 py-1 text-xs font-semibold uppercase text-slate-700">Workspace</p>
        <h2 class="mt-3 text-base font-semibold text-slate-950">Keep family records together</h2>
        <p class="mt-2 text-sm leading-6 text-slate-700">Your account groups documents, extracted pages, and search context under one workspace.</p>
      </article>

      <article class="rounded-lg border border-slate-200 bg-white px-5 py-4 shadow-sm">
        <p class="inline-flex rounded-md bg-slate-100 px-2 py-1 text-xs font-semibold uppercase text-slate-700">Review</p>
        <h2 class="mt-3 text-base font-semibold text-slate-950">Move from upload to evidence</h2>
        <p class="mt-2 text-sm leading-6 text-slate-700">Process documents into chunks, search answers, and source-linked timeline events.</p>
      </article>
    </div>
  </section>

  <section class="h-fit rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
    <h2 class="text-xl font-semibold text-slate-950">Set up your workspace</h2>
    <p class="mt-1 text-sm text-slate-600">Use this account to manage documents for one workspace.</p>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "mt-6 space-y-4" }) do |f| %>
      <% if resource.errors.any? %>
        <div class="rounded-lg border border-red-200 bg-red-50 p-4 text-red-900" role="alert">
          <h3 class="text-sm font-semibold"><%= pluralize(resource.errors.count, "error") %> prevented this account from being created</h3>
          <ul class="mt-2 list-disc space-y-1 pl-5 text-sm">
            <% resource.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :account_name, "Workspace name", class: "block text-sm font-medium text-slate-700" %>
        <%= f.text_field :account_name, value: params.dig(resource_name, :account_name), autocomplete: "organization", class: "mt-2 block w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm text-slate-950 shadow-sm outline-none focus:border-emerald-600 focus:ring-2 focus:ring-emerald-100" %>
      </div>

      <div>
        <%= f.label :name, class: "block text-sm font-medium text-slate-700" %>
        <%= f.text_field :name, autocomplete: "name", class: "mt-2 block w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm text-slate-950 shadow-sm outline-none focus:border-emerald-600 focus:ring-2 focus:ring-emerald-100" %>
      </div>

      <div>
        <%= f.label :email, class: "block text-sm font-medium text-slate-700" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "mt-2 block w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm text-slate-950 shadow-sm outline-none focus:border-emerald-600 focus:ring-2 focus:ring-emerald-100" %>
      </div>

      <div>
        <%= f.label :password, class: "block text-sm font-medium text-slate-700" %>
        <% if @minimum_password_length %>
          <p class="mt-1 text-xs text-slate-500"><%= @minimum_password_length %> characters minimum</p>
        <% end %>
        <%= f.password_field :password, autocomplete: "new-password", class: "mt-2 block w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm text-slate-950 shadow-sm outline-none focus:border-emerald-600 focus:ring-2 focus:ring-emerald-100" %>
      </div>

      <div>
        <%= f.label :password_confirmation, class: "block text-sm font-medium text-slate-700" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "mt-2 block w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm text-slate-950 shadow-sm outline-none focus:border-emerald-600 focus:ring-2 focus:ring-emerald-100" %>
      </div>

      <%= f.submit "Create account", class: "w-full rounded-md bg-emerald-700 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-800" %>
    <% end %>

    <div class="mt-4 rounded-lg border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-700">
      Already have an account?
      <%= link_to "Sign in", new_session_path(resource_name), class: "font-semibold text-emerald-700 hover:text-emerald-900" %>
    </div>
  </section>
</main>
