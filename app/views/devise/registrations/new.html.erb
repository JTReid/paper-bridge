<% content_for :title, "Create Account | PaperBridge" %>

<main class="min-h-screen bg-background text-foreground">
  <div class="mx-auto flex min-h-screen max-w-6xl flex-col px-5 py-6 sm:px-6 lg:px-8">
    <header class="flex items-center justify-between">
      <%= link_to root_path, class: "flex items-center", aria: { label: "PaperBridge home" } do %>
        <%= paperbridge_logo(width: 150, height: 52, class_name: "h-[52px] w-[150px]") %>
      <% end %>

      <%= link_to "Sign in", new_session_path(resource_name), class: "inline-flex h-10 items-center justify-center rounded-full border border-border bg-white px-5 text-sm font-medium text-foreground shadow-sm transition-colors hover:bg-muted" %>
    </header>

    <section class="grid flex-1 items-center gap-10 py-10 lg:grid-cols-[minmax(0,1fr)_27rem] lg:py-16">
      <div class="max-w-2xl">
        <div class="mb-6 inline-flex items-center gap-2 rounded-full bg-primary/5 px-3 py-1.5">
          <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
          <span class="text-xs font-medium text-primary">AI-Powered Care Advocacy</span>
        </div>

        <h1 class="text-4xl font-bold leading-tight tracking-tight text-foreground md:text-5xl">
          Create account
        </h1>
        <p class="mt-5 max-w-xl text-lg leading-8 text-muted-foreground">
          Start a PaperBridge workspace to organize care records, understand complex documents, and prepare for conversations with your care team.
        </p>

        <div class="mt-8 grid gap-4 sm:grid-cols-3">
          <% [
            ["folder-open", "Organize", "Keep records in one place."],
            ["brain", "Understand", "Turn documents into clear summaries."],
            ["share-2", "Advocate", "Share context with the right people."]
          ].each do |icon, title, copy| %>
            <article class="rounded-2xl border border-border/50 bg-white p-5 shadow-sm">
              <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-xl bg-primary/10 text-primary">
                <%= pb_icon(icon, class_name: "h-5 w-5") %>
              </div>
              <h2 class="text-sm font-semibold text-foreground"><%= title %></h2>
              <p class="mt-2 text-xs leading-relaxed text-muted-foreground"><%= copy %></p>
            </article>
          <% end %>
        </div>
      </div>

      <section class="rounded-2xl border border-border/60 bg-white p-6 shadow-2xl shadow-primary/10 sm:p-7">
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-primary">New Workspace</p>
          <h2 class="mt-2 text-2xl font-bold tracking-tight text-foreground">Set up PaperBridge</h2>
          <p class="mt-1 text-sm text-muted-foreground">Use this login to manage your family workspace.</p>
        </div>

        <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "mt-6 space-y-4" }) do |f| %>
          <% if resource.errors.any? %>
            <div class="rounded-xl border border-red-200 bg-red-50 p-4 text-red-900" role="alert">
              <h3 class="text-sm font-semibold"><%= pluralize(resource.errors.count, "error") %> prevented this account from being created</h3>
              <ul class="mt-2 list-disc space-y-1 pl-5 text-sm">
                <% resource.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <div>
            <%= f.label :account_name, "Workspace name", class: "block text-sm font-medium text-foreground" %>
            <%= f.text_field :account_name, value: params.dig(resource_name, :account_name), autocomplete: "organization", class: "mt-2 block h-11 w-full rounded-xl border border-border bg-white px-3 text-sm text-foreground shadow-sm outline-none transition-colors focus:border-primary focus:ring-2 focus:ring-primary/10" %>
          </div>

          <div>
            <%= f.label :name, class: "block text-sm font-medium text-foreground" %>
            <%= f.text_field :name, autocomplete: "name", class: "mt-2 block h-11 w-full rounded-xl border border-border bg-white px-3 text-sm text-foreground shadow-sm outline-none transition-colors focus:border-primary focus:ring-2 focus:ring-primary/10" %>
          </div>

          <div>
            <%= f.label :email, class: "block text-sm font-medium text-foreground" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "mt-2 block h-11 w-full rounded-xl border border-border bg-white px-3 text-sm text-foreground shadow-sm outline-none transition-colors focus:border-primary focus:ring-2 focus:ring-primary/10" %>
          </div>

          <div>
            <div class="flex items-center justify-between gap-3">
              <%= f.label :password, class: "block text-sm font-medium text-foreground" %>
              <% if @minimum_password_length %>
                <span class="text-xs text-muted-foreground"><%= @minimum_password_length %> characters minimum</span>
              <% end %>
            </div>
            <%= f.password_field :password, autocomplete: "new-password", class: "mt-2 block h-11 w-full rounded-xl border border-border bg-white px-3 text-sm text-foreground shadow-sm outline-none transition-colors focus:border-primary focus:ring-2 focus:ring-primary/10" %>
          </div>

          <div>
            <%= f.label :password_confirmation, class: "block text-sm font-medium text-foreground" %>
            <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "mt-2 block h-11 w-full rounded-xl border border-border bg-white px-3 text-sm text-foreground shadow-sm outline-none transition-colors focus:border-primary focus:ring-2 focus:ring-primary/10" %>
          </div>

          <%= f.submit "Create account", class: "h-11 w-full rounded-full bg-primary px-4 text-sm font-semibold text-primary-foreground shadow-lg shadow-primary/20 transition-colors hover:bg-primary/90" %>
        <% end %>

        <div class="mt-5 rounded-xl border border-border bg-muted/40 px-4 py-3 text-sm text-muted-foreground">
          Already have an account?
          <%= link_to "Sign in", new_session_path(resource_name), class: "font-semibold text-primary hover:opacity-80" %>
        </div>
      </section>
    </section>
  </div>
</main>
