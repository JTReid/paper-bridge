<% content_for :title, "Sign In | PaperBridge" %>

<main class="min-h-screen bg-background text-foreground">
  <div class="mx-auto flex min-h-screen max-w-6xl flex-col px-5 py-6 sm:px-6 lg:px-8">
    <header class="flex items-center justify-between">
      <%= link_to root_path, class: "flex items-center", aria: { label: "PaperBridge home" } do %>
        <%= paperbridge_logo(width: 150, height: 52, class_name: "h-[52px] w-[150px]") %>
      <% end %>

      <%= link_to "Create account", new_registration_path(resource_name), class: "inline-flex h-10 items-center justify-center rounded-full border border-border bg-white px-5 text-sm font-medium text-foreground shadow-sm transition-colors hover:bg-muted" %>
    </header>

    <section class="grid flex-1 items-center gap-10 py-10 lg:grid-cols-[minmax(0,1fr)_27rem] lg:py-16">
      <div class="max-w-2xl">
        <div class="mb-6 inline-flex items-center gap-2 rounded-full bg-primary/5 px-3 py-1.5">
          <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
          <span class="text-xs font-medium text-primary">Secure Family Workspace</span>
        </div>

        <h1 class="text-4xl font-bold leading-tight tracking-tight text-foreground md:text-5xl">
          Sign in
        </h1>
        <p class="mt-5 max-w-xl text-lg leading-8 text-muted-foreground">
          Open your PaperBridge workspace to review user profiles, manage care records, and ask AI-assisted questions grounded in your documents.
        </p>

        <div class="mt-8 grid gap-4 sm:grid-cols-3">
          <% [
            ["user-circle", "Profiles", "Pick up where you left off."],
            ["file-text", "Records", "Search organized documents."],
            ["brain", "AI Assistant", "Get cited answers from evidence."]
          ].each do |icon, title, copy| %>
            <article class="rounded-2xl border border-border/50 bg-white p-5 shadow-sm">
              <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-xl bg-primary/10 text-primary">
                <%= pb_icon(icon, class_name: "h-5 w-5") %>
              </div>
              <h2 class="text-sm font-semibold text-foreground"><%= title %></h2>
              <p class="mt-2 text-xs leading-relaxed text-muted-foreground"><%= copy %></p>
            </article>
          <% end %>
        </div>
      </div>

      <section class="rounded-2xl border border-border/60 bg-white p-6 shadow-2xl shadow-primary/10 sm:p-7">
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-primary">Welcome Back</p>
          <h2 class="mt-2 text-2xl font-bold tracking-tight text-foreground">Sign in to PaperBridge</h2>
          <p class="mt-1 text-sm text-muted-foreground">Use your account credentials to continue.</p>
        </div>

        <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "mt-6 space-y-4" }) do |f| %>
          <div>
            <%= f.label :email, class: "block text-sm font-medium text-foreground" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "mt-2 block h-11 w-full rounded-xl border border-border bg-white px-3 text-sm text-foreground shadow-sm outline-none transition-colors focus:border-primary focus:ring-2 focus:ring-primary/10" %>
          </div>

          <div>
            <div class="flex items-center justify-between gap-3">
              <%= f.label :password, class: "block text-sm font-medium text-foreground" %>
              <% if devise_mapping.recoverable? %>
                <%= link_to "Forgot your password?", new_password_path(resource_name), class: "text-xs font-semibold text-primary hover:opacity-80" %>
              <% end %>
            </div>
            <%= f.password_field :password, autocomplete: "current-password", class: "mt-2 block h-11 w-full rounded-xl border border-border bg-white px-3 text-sm text-foreground shadow-sm outline-none transition-colors focus:border-primary focus:ring-2 focus:ring-primary/10" %>
          </div>

          <% if devise_mapping.rememberable? %>
            <label class="flex items-center gap-2 text-sm font-medium text-muted-foreground">
              <%= f.check_box :remember_me, class: "h-4 w-4 rounded border-border text-primary focus:ring-primary" %>
              Remember me
            </label>
          <% end %>

          <%= f.submit "Sign in", class: "h-11 w-full rounded-full bg-primary px-4 text-sm font-semibold text-primary-foreground shadow-lg shadow-primary/20 transition-colors hover:bg-primary/90" %>
        <% end %>

        <div class="mt-5 rounded-xl border border-border bg-muted/40 px-4 py-3 text-sm text-muted-foreground">
          Need an account?
          <%= link_to "Create one", new_registration_path(resource_name), class: "font-semibold text-primary hover:opacity-80" %>
        </div>
      </section>
    </section>
  </div>
</main>
