<main class="mx-auto grid max-w-7xl gap-8 px-4 py-8 sm:px-6 lg:grid-cols-[minmax(0,1fr)_24rem] lg:px-8">
  <section class="flex flex-col gap-6">
    <header class="border-b border-slate-200 pb-6">
      <%= link_to root_path, class: "inline-flex items-center text-sm font-medium text-slate-600 hover:text-slate-950" do %>
        <span aria-hidden="true" class="mr-2">&larr;</span>
        PaperBridge
      <% end %>

      <div class="mt-8 max-w-3xl">
        <p class="inline-flex rounded-md bg-emerald-50 px-2.5 py-1 text-xs font-semibold uppercase text-emerald-800">Secure workspace</p>
        <h1 class="mt-4 text-3xl font-semibold text-slate-950">Sign in</h1>
        <p class="mt-3 text-base leading-7 text-slate-600">
          Open your account workspace to upload records, search indexed evidence, and review extracted timelines.
        </p>
      </div>
    </header>

    <div class="grid gap-4 md:grid-cols-2">
      <article class="rounded-lg border border-slate-200 bg-white px-5 py-4 shadow-sm">
        <p class="inline-flex rounded-md bg-slate-100 px-2 py-1 text-xs font-semibold uppercase text-slate-700">Evidence</p>
        <h2 class="mt-3 text-base font-semibold text-slate-950">Search document context</h2>
        <p class="mt-2 text-sm leading-6 text-slate-700">Ask questions against processed chunks while keeping source citations visible.</p>
      </article>

      <article class="rounded-lg border border-slate-200 bg-white px-5 py-4 shadow-sm">
        <p class="inline-flex rounded-md bg-slate-100 px-2 py-1 text-xs font-semibold uppercase text-slate-700">Timeline</p>
        <h2 class="mt-3 text-base font-semibold text-slate-950">Review extracted events</h2>
        <p class="mt-2 text-sm leading-6 text-slate-700">Move quickly from source documents to dated and undated event review.</p>
      </article>
    </div>
  </section>

  <section class="h-fit rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
    <h2 class="text-xl font-semibold text-slate-950">Welcome back</h2>
    <p class="mt-1 text-sm text-slate-600">Use your PaperBridge account credentials.</p>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "mt-6 space-y-4" }) do |f| %>
      <div>
        <%= f.label :email, class: "block text-sm font-medium text-slate-700" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "mt-2 block w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm text-slate-950 shadow-sm outline-none focus:border-emerald-600 focus:ring-2 focus:ring-emerald-100" %>
      </div>

      <div>
        <%= f.label :password, class: "block text-sm font-medium text-slate-700" %>
        <%= f.password_field :password, autocomplete: "current-password", class: "mt-2 block w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm text-slate-950 shadow-sm outline-none focus:border-emerald-600 focus:ring-2 focus:ring-emerald-100" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="flex items-center gap-2">
          <%= f.check_box :remember_me, class: "rounded-md border border-slate-300 bg-white text-emerald-700" %>
          <%= f.label :remember_me, class: "text-sm font-medium text-slate-700" %>
        </div>
      <% end %>

      <%= f.submit "Sign in", class: "w-full rounded-md bg-emerald-700 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-800" %>
    <% end %>

    <div class="mt-4 border-t border-slate-100 pt-3 text-sm">
      <% if devise_mapping.recoverable? %>
        <%= link_to "Forgot your password?", new_password_path(resource_name), class: "font-medium text-slate-600 hover:text-slate-950" %>
      <% end %>
    </div>

    <% if devise_mapping.registerable? %>
      <div class="mt-4 rounded-lg border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-700">
        Need an account?
        <%= link_to "Create one", new_registration_path(resource_name), class: "font-semibold text-emerald-700 hover:text-emerald-900" %>
      </div>
    <% end %>
  </section>
</main>
