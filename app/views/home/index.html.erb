<main class="mx-auto flex max-w-7xl flex-col gap-8 px-4 py-8 sm:px-6 lg:px-8">
  <header class="flex flex-col gap-6 border-b border-slate-200 pb-6 lg:flex-row lg:items-end lg:justify-between">
    <div class="max-w-3xl">
      <p class="inline-flex rounded-md bg-emerald-50 px-2.5 py-1 text-xs font-semibold uppercase text-emerald-800">Document intelligence</p>
      <h1 class="mt-4 text-3xl font-semibold text-slate-950">PaperBridge</h1>
      <p class="mt-3 text-base leading-7 text-slate-600">
        A focused workspace for turning records into searchable evidence, extracted timelines, and account-scoped context.
      </p>
    </div>

    <div class="flex flex-col gap-3 sm:flex-row">
      <% if user_signed_in? %>
        <%= link_to "Documents", documents_path, class: "inline-flex justify-center rounded-md bg-emerald-700 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-800" %>
        <%= link_to "Timeline", timeline_path, class: "inline-flex justify-center rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50" %>
      <% else %>
        <%= link_to "Sign in", new_user_session_path, class: "inline-flex justify-center rounded-md bg-emerald-700 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-800" %>
        <%= link_to "Create account", new_user_registration_path, class: "inline-flex justify-center rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50" %>
      <% end %>
    </div>
  </header>

  <% if user_signed_in? %>
    <section class="rounded-lg border border-slate-200 bg-white p-4 shadow-sm">
      <%= form_with url: search_path, method: :get, class: "flex flex-col gap-3 sm:flex-row" do |form| %>
        <%= form.search_field :q, placeholder: "Search indexed document chunks", class: "block w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm text-slate-950 shadow-sm outline-none focus:border-emerald-600 focus:ring-2 focus:ring-emerald-100" %>
        <%= form.submit "Search", class: "rounded-md bg-emerald-700 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-800" %>
      <% end %>
    </section>
  <% end %>

  <section class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_24rem]">
    <div class="space-y-4">
      <div>
        <h2 class="text-xl font-semibold text-slate-950">Evidence Workflow</h2>
        <p class="mt-1 text-sm text-slate-600">Move from raw documents to reviewable context without leaving the app.</p>
      </div>

      <div class="grid gap-4 md:grid-cols-2">
        <article class="rounded-lg border border-slate-200 bg-white px-5 py-4 shadow-sm">
          <p class="inline-flex rounded-md bg-slate-100 px-2 py-1 text-xs font-semibold uppercase text-slate-700">Upload</p>
          <h3 class="mt-3 text-base font-semibold text-slate-950">Centralize records</h3>
          <p class="mt-2 text-sm leading-6 text-slate-700">Add source files to the account workspace so pages, chunks, and metadata stay connected.</p>
          <% if user_signed_in? %>
            <%= link_to "Upload document", new_document_path, class: "mt-4 inline-flex text-sm font-medium text-emerald-700 hover:text-emerald-900" %>
          <% end %>
        </article>

        <article class="rounded-lg border border-slate-200 bg-white px-5 py-4 shadow-sm">
          <p class="inline-flex rounded-md bg-slate-100 px-2 py-1 text-xs font-semibold uppercase text-slate-700">Search</p>
          <h3 class="mt-3 text-base font-semibold text-slate-950">Ask across evidence</h3>
          <p class="mt-2 text-sm leading-6 text-slate-700">Use indexed chunks and citations to answer questions with visible source context.</p>
          <% if user_signed_in? %>
            <%= link_to "Search documents", search_path, class: "mt-4 inline-flex text-sm font-medium text-emerald-700 hover:text-emerald-900" %>
          <% end %>
        </article>

        <article class="rounded-lg border border-slate-200 bg-white px-5 py-4 shadow-sm">
          <p class="inline-flex rounded-md bg-slate-100 px-2 py-1 text-xs font-semibold uppercase text-slate-700">Timeline</p>
          <h3 class="mt-3 text-base font-semibold text-slate-950">Review extracted events</h3>
          <p class="mt-2 text-sm leading-6 text-slate-700">Scan dated and undated events alongside the quotes and documents they came from.</p>
          <% if user_signed_in? %>
            <%= link_to "View timeline", timeline_path, class: "mt-4 inline-flex text-sm font-medium text-emerald-700 hover:text-emerald-900" %>
          <% end %>
        </article>

        <article class="rounded-lg border border-slate-200 bg-white px-5 py-4 shadow-sm">
          <p class="inline-flex rounded-md bg-slate-100 px-2 py-1 text-xs font-semibold uppercase text-slate-700">Access</p>
          <h3 class="mt-3 text-base font-semibold text-slate-950">Keep context scoped</h3>
          <p class="mt-2 text-sm leading-6 text-slate-700">Account membership and roles keep document retrieval focused on the right family workspace.</p>
        </article>
      </div>
    </div>

    <% if user_signed_in? %>
      <aside class="h-fit rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
        <h2 class="text-sm font-semibold uppercase text-slate-500">Workspace</h2>
        <dl class="mt-4 divide-y divide-slate-100 text-sm">
          <div class="py-3">
            <dt class="font-medium text-slate-500">Signed in</dt>
            <dd class="mt-1 break-words text-slate-950"><%= current_user.name.presence || current_user.email %></dd>
          </div>
          <div class="py-3">
            <dt class="font-medium text-slate-500">Account</dt>
            <dd class="mt-1 break-words text-slate-950"><%= current_user.account.name %></dd>
          </div>
          <div class="py-3">
            <dt class="font-medium text-slate-500">Role</dt>
            <dd class="mt-1 text-slate-950"><%= current_user.role.humanize %></dd>
          </div>
        </dl>

        <div class="mt-4 flex flex-col gap-3">
          <%= link_to "Open documents", documents_path, class: "inline-flex justify-center rounded-md bg-emerald-700 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-800" %>
          <%= button_to "Sign out", destroy_user_session_path, method: :delete, form_class: "inline", class: "rounded-md px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-100" %>
        </div>
      </aside>
    <% else %>
      <aside class="h-fit rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
        <h2 class="text-sm font-semibold uppercase text-slate-500">Get Started</h2>
        <p class="mt-3 text-sm leading-6 text-slate-700">
          Sign in to open your workspace, upload documents, and search processed evidence.
        </p>

        <div class="mt-4 flex flex-col gap-3">
          <%= link_to "Sign in", new_user_session_path, class: "inline-flex justify-center rounded-md bg-emerald-700 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-800" %>
          <%= link_to "Create account", new_user_registration_path, class: "inline-flex justify-center rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50" %>
        </div>
      </aside>
    <% end %>
  </section>
</main>
