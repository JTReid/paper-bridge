<% content_for :title, "PaperBridge" %>

<%
  primary_path = user_signed_in? ? dashboard_path : new_user_registration_path
  primary_label = user_signed_in? ? "Open dashboard" : "Get Started"
  nav_primary_label = user_signed_in? ? "Dashboard" : "Get Started"
  secondary_path = user_signed_in? ? dashboard_path : new_user_session_path
  secondary_label = user_signed_in? ? "Dashboard" : "Sign In"

  problems = [
    {
      icon: "file-search",
      title: "Scattered documents",
      description: "Records live across emails, portals, folders, and paper files with no single source of truth."
    },
    {
      icon: "alert-triangle",
      title: "Missed details",
      description: "Important information gets buried in lengthy reports and complex evaluations."
    },
    {
      icon: "message-square",
      title: "Repeated explanations",
      description: "Parents explain the same history to every new teacher, therapist, and provider."
    },
    {
      icon: "clock",
      title: "Stress before meetings",
      description: "Preparing for IEP or care meetings means hours of searching and organizing."
    }
  ]

  solutions = [
    {
      icon: "folder-open",
      title: "Organize",
      description: "Upload and store educational, medical, therapy, and insurance documents in one place.",
      color: "bg-primary/10 text-primary"
    },
    {
      icon: "brain",
      title: "Understand",
      description: "AI turns complex reports into clear summaries and key takeaways.",
      color: "bg-accent/30 text-accent-foreground"
    },
    {
      icon: "share-2",
      title: "Share",
      description: "Give teachers, therapists, doctors, or family members controlled read-only access.",
      color: "bg-primary/10 text-primary"
    }
  ]

  feature_groups = [
    {
      title: "Document Library",
      subtitle: "All your records, organized beautifully.",
      items: [
        ["upload", "Single and bulk upload"],
        ["search", "Search across all documents"],
        ["eye", "Document preview"],
        ["list-checks", "Smart categories"]
      ]
    },
    {
      title: "AI Summaries",
      subtitle: "Complex reports made simple.",
      items: [
        ["brain", "Auto-generated summaries"],
        ["clock", "Pending to processing to ready"],
        ["check-circle", "Key takeaways extracted"],
        ["sparkles", "Suggested tags"]
      ]
    },
    {
      title: "Care Team Access",
      subtitle: "The right people see the right information.",
      items: [
        ["users", "Invite teachers, therapists, doctors"],
        ["lock", "Category-level permissions"],
        ["eye", "Read-only access"],
        ["check-circle", "Parent-controlled sharing"]
      ]
    },
    {
      title: "Share by Email",
      subtitle: "Share insights with one click.",
      items: [
        ["mail", "Share AI summaries"],
        ["send", "Share document details"],
        ["eye", "Content preview before sending"],
        ["check-circle", "Server-side delivery"]
      ]
    },
    {
      title: "Advocacy Copilot",
      subtitle: "From paperwork to action.",
      items: [
        ["sparkles", "Prepare for IEP meetings"],
        ["help-circle", "Suggested questions"],
        ["trending-up", "Progress highlights"],
        ["alert-circle", "Missing information alerts"]
      ]
    }
  ]

  before_items = [
    "Documents everywhere",
    "Hard to understand reports",
    "Constantly searching",
    "Repeating the same story",
    "Stressful meetings"
  ]

  after_items = [
    "Everything in one place",
    "Clear AI summaries",
    "Easy sharing with care team",
    "Prepared for meetings",
    "Stronger advocacy"
  ]

  roles = [
    ["graduation-cap", "Teacher", "bg-primary/10 text-primary"],
    ["heart", "Therapist", "bg-accent/40 text-accent-foreground"],
    ["stethoscope", "Doctor", "bg-red-50 text-red-700"],
    ["users", "Parent", "bg-amber-50 text-amber-700"],
    ["user-circle", "Family Member", "bg-primary/10 text-primary"],
    ["help-circle", "Other", "bg-muted text-muted-foreground"]
  ]

  permissions = [
    ["Educational", true],
    ["Medical", false],
    ["Therapy", true],
    ["Insurance", false]
  ]

  advocacy_cards = [
    {
      icon: "sparkles",
      title: "Prepare for Meeting",
      description: "Get a clear overview of key topics, goals, and progress before your next IEP or care meeting."
    },
    {
      icon: "git-compare",
      title: "What Changed?",
      description: "See what's new since your last meeting - new evaluations, updated goals, and changes in services."
    },
    {
      icon: "help-circle",
      title: "Suggested Questions",
      description: "AI-generated questions to help you get the most out of your conversations with providers."
    },
    {
      icon: "alert-circle",
      title: "Missing Information",
      description: "Identifies gaps in records so you can request what's needed before it's too late."
    },
    {
      icon: "trending-up",
      title: "Progress Highlights",
      description: "Pulls key progress indicators from documents so you can see how your child is doing at a glance."
    }
  ]

  privacy_items = [
    {
      icon: "user-check",
      title: "Parent-controlled sharing",
      description: "You decide who sees what. Every permission is in your hands."
    },
    {
      icon: "eye",
      title: "Read-only access",
      description: "Care team members can view - never upload, edit, delete, or re-share."
    },
    {
      icon: "lock",
      title: "Category permissions",
      description: "Grant access to specific document categories, not everything."
    },
    {
      icon: "shield",
      title: "Privacy-first design",
      description: "Your child's story is protected. Secure organization from the ground up."
    }
  ]
%>

<main class="min-h-screen bg-background text-foreground">
  <nav class="fixed left-0 right-0 top-0 z-50 border-b border-border/50 bg-white/80 backdrop-blur-xl">
    <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-6">
      <%= link_to root_path, class: "flex items-center", aria: { label: "PaperBridge home" } do %>
        <%= paperbridge_logo(width: 160, height: 56, class_name: "h-14 w-40") %>
      <% end %>

      <div class="hidden items-center gap-8 md:flex">
        <a href="#features" class="text-sm text-muted-foreground transition-colors hover:text-foreground">Features</a>
        <a href="#how-it-works" class="text-sm text-muted-foreground transition-colors hover:text-foreground">How It Works</a>
        <a href="#care-team" class="text-sm text-muted-foreground transition-colors hover:text-foreground">Care Team</a>
        <a href="#privacy" class="text-sm text-muted-foreground transition-colors hover:text-foreground">Privacy</a>
      </div>

      <div class="hidden items-center gap-3 md:flex">
        <%= link_to secondary_label, secondary_path, class: "inline-flex h-9 items-center justify-center rounded-md px-4 py-2 text-sm font-medium transition-colors hover:bg-accent hover:text-accent-foreground", data: { testid: "home-nav-secondary" } %>
        <%= link_to nav_primary_label, primary_path, class: "inline-flex h-9 items-center justify-center rounded-full bg-primary px-5 py-2 text-sm font-medium text-primary-foreground shadow transition-colors hover:bg-primary/90", data: { testid: "home-nav-primary" } %>
      </div>

      <details class="group md:hidden">
        <summary class="flex h-10 w-10 cursor-pointer list-none items-center justify-center rounded-full text-foreground transition-colors hover:bg-muted [&::-webkit-details-marker]:hidden">
          <%= pb_icon("menu", class_name: "h-5 w-5") %>
        </summary>
        <div class="absolute left-0 right-0 top-16 border-b border-border bg-white px-6 py-4 shadow-sm">
          <div class="space-y-3">
            <a href="#features" class="block text-sm text-muted-foreground">Features</a>
            <a href="#how-it-works" class="block text-sm text-muted-foreground">How It Works</a>
            <a href="#care-team" class="block text-sm text-muted-foreground">Care Team</a>
            <a href="#privacy" class="block text-sm text-muted-foreground">Privacy</a>
            <div class="space-y-2 border-t border-border pt-3">
              <%= link_to secondary_label, secondary_path, class: "block rounded-md px-3 py-2 text-sm font-medium text-foreground hover:bg-muted", data: { testid: "home-mobile-secondary" } %>
              <%= link_to nav_primary_label, primary_path, class: "block rounded-full bg-primary px-4 py-2 text-center text-sm font-medium text-primary-foreground", data: { testid: "home-mobile-primary" } %>
            </div>
          </div>
        </div>
      </details>
    </div>
  </nav>

  <section class="relative overflow-hidden pb-20 pt-32 md:pb-28 md:pt-40">
    <div class="absolute inset-0 bg-gradient-to-b from-primary/[0.02] via-transparent to-accent/[0.03]"></div>

    <div class="relative mx-auto max-w-7xl px-6">
      <div class="mx-auto mb-16 max-w-3xl text-center" data-controller="reveal">
        <div class="mb-6 inline-flex items-center gap-2 rounded-full bg-primary/5 px-3 py-1.5">
          <div class="h-1.5 w-1.5 animate-pulse rounded-full bg-accent"></div>
          <span class="text-xs font-medium text-primary">AI-Powered Care Advocacy</span>
        </div>

        <h1 class="mb-6 text-4xl font-bold leading-[1.08] tracking-tight text-foreground md:text-6xl lg:text-7xl">
          Turn overwhelming paperwork into <span class="text-primary">clarity.</span>
        </h1>

        <p class="mx-auto mb-3 max-w-2xl text-lg leading-relaxed text-muted-foreground md:text-xl">
          PaperBridge is an AI-powered platform that helps families organize, understand, and share everything related to their child's care in one place.
        </p>

        <p class="mb-8 text-sm text-muted-foreground">
          Spend less time searching through documents and more time focusing on your child.
        </p>

        <div class="flex flex-col items-center justify-center gap-3 sm:flex-row">
          <%= link_to primary_path, class: "inline-flex h-12 items-center justify-center rounded-full bg-primary px-8 text-sm font-medium text-primary-foreground shadow-lg shadow-primary/20 transition-colors hover:bg-primary/90", data: { testid: "home-hero-primary" } do %>
            <%= primary_label %>
            <%= pb_icon("arrow-right", class_name: "ml-2 h-4 w-4") %>
          <% end %>
          <a href="#how-it-works" class="inline-flex h-12 items-center justify-center rounded-full border border-border bg-transparent px-8 text-sm font-medium shadow-sm transition-colors hover:bg-accent hover:text-accent-foreground">
            <%= pb_icon("play", class_name: "mr-2 h-4 w-4") %>
            Watch How It Works
          </a>
        </div>
      </div>

      <div class="relative mx-auto max-w-4xl" data-controller="reveal" data-reveal-delay-value="120">
        <div class="overflow-hidden rounded-2xl border border-border/60 bg-white shadow-2xl shadow-primary/10">
          <div class="flex items-center gap-2 border-b border-border/60 bg-muted/30 px-5 py-3">
            <div class="flex gap-1.5">
              <div class="h-2.5 w-2.5 rounded-full bg-red-400/60"></div>
              <div class="h-2.5 w-2.5 rounded-full bg-yellow-400/60"></div>
              <div class="h-2.5 w-2.5 rounded-full bg-green-400/60"></div>
            </div>
            <div class="flex flex-1 justify-center">
              <div class="rounded-md bg-muted px-4 py-1 text-xs text-muted-foreground">paperbridge.app/dashboard</div>
            </div>
          </div>

          <div class="grid min-h-[320px] grid-cols-12 gap-4 p-4 sm:p-6">
            <div class="col-span-3 hidden space-y-3 md:block">
              <div class="flex items-center gap-2 rounded-lg bg-primary/5 px-3 py-2">
                <div class="flex h-6 w-6 items-center justify-center rounded-full bg-primary/10">
                  <span class="text-[10px] font-semibold text-primary">EM</span>
                </div>
                <span class="text-xs font-medium text-foreground">Emma's Profile</span>
              </div>

              <div class="flex items-center gap-2 rounded-lg px-3 py-1.5 text-xs text-muted-foreground">
                <%= pb_icon("file-text", class_name: "h-3.5 w-3.5") %>
                <span>Documents</span>
              </div>
              <div class="flex items-center gap-2 rounded-lg bg-primary px-3 py-1.5 text-xs text-white">
                <%= pb_icon("brain", class_name: "h-3.5 w-3.5") %>
                <span>AI Summaries</span>
              </div>
              <div class="flex items-center gap-2 rounded-lg px-3 py-1.5 text-xs text-muted-foreground">
                <%= pb_icon("users", class_name: "h-3.5 w-3.5") %>
                <span>Care Team</span>
              </div>
              <div class="flex items-center gap-2 rounded-lg px-3 py-1.5 text-xs text-muted-foreground">
                <%= pb_icon("share-2", class_name: "h-3.5 w-3.5") %>
                <span>Shared</span>
              </div>
            </div>

            <div class="col-span-12 space-y-4 md:col-span-9">
              <div class="flex items-center gap-3 rounded-xl bg-muted/40 p-3">
                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-accent/40 text-sm font-semibold text-primary">E</div>
                <div>
                  <p class="text-sm font-semibold text-foreground">Emma Johnson</p>
                  <p class="text-xs text-muted-foreground">3rd Grade &middot; Maplewood Elementary</p>
                </div>
                <div class="ml-auto hidden rounded-full bg-green-50 px-2 py-0.5 text-[10px] font-medium text-green-700 sm:block">4 Summaries Ready</div>
              </div>

              <div class="grid grid-cols-2 gap-3">
                <% [["Educational", 8, "bg-primary/10 text-primary"], ["Medical", 5, "bg-red-50 text-red-700"], ["Therapy", 6, "bg-green-50 text-green-700"], ["Insurance", 3, "bg-amber-50 text-amber-700"]].each do |label, count, color| %>
                  <div class="rounded-xl border border-border/60 bg-white p-3">
                    <p class="text-xs text-muted-foreground"><%= label %></p>
                    <p class="mt-1 text-lg font-semibold text-foreground"><%= count %></p>
                    <div class="mt-1.5 inline-block rounded-full px-2 py-0.5 text-[10px] font-medium <%= color %>">
                      <%= count %> documents
                    </div>
                  </div>
                <% end %>
              </div>

              <div class="rounded-xl border border-primary/10 bg-primary/5 p-3">
                <div class="mb-2 flex items-center gap-2">
                  <%= pb_icon("brain", class_name: "h-3.5 w-3.5 text-primary") %>
                  <p class="text-xs font-semibold text-primary">AI Summary</p>
                  <div class="ml-auto rounded-full bg-green-100 px-2 py-0.5 text-[10px] font-medium text-green-700">Ready</div>
                </div>
                <p class="text-xs leading-relaxed text-muted-foreground">
                  Emma's latest IEP evaluation shows significant progress in reading comprehension. Speech therapy goals are being met on schedule...
                </p>
              </div>
            </div>
          </div>
        </div>

        <div class="absolute -left-4 top-1/3 hidden items-center gap-2 rounded-xl border border-border/60 bg-white px-3 py-2 shadow-lg lg:flex" data-controller="reveal" data-reveal-delay-value="220">
          <%= pb_icon("shield", class_name: "h-4 w-4 text-accent") %>
          <span class="text-xs font-medium text-foreground">Secure and Private</span>
        </div>

        <div class="absolute -right-4 top-1/2 hidden items-center gap-2 rounded-xl border border-border/60 bg-white px-3 py-2 shadow-lg lg:flex" data-controller="reveal" data-reveal-delay-value="300">
          <%= pb_icon("share-2", class_name: "h-4 w-4 text-primary") %>
          <span class="text-xs font-medium text-foreground">Share with Care Team</span>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white py-24 md:py-32">
    <div class="mx-auto max-w-7xl px-6">
      <div class="mb-16 max-w-2xl" data-controller="reveal">
        <p class="mb-4 text-xs font-semibold uppercase tracking-widest text-primary">The Problem</p>
        <h2 class="mb-5 text-3xl font-bold leading-tight tracking-tight text-foreground md:text-5xl">Care records should not live in chaos.</h2>
        <p class="text-lg leading-relaxed text-muted-foreground">
          Families often manage IEPs, evaluations, therapy notes, medical records, insurance forms, and school documents across emails, portals, folders, and paper files. PaperBridge brings everything together.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-5 md:grid-cols-2 lg:grid-cols-4">
        <% problems.each_with_index do |item, index| %>
          <article class="group rounded-2xl border border-border/50 bg-muted/40 p-6 transition-all duration-300 hover:border-destructive/20 hover:bg-destructive/[0.02]" data-controller="reveal" data-reveal-delay-value="<%= index * 70 %>">
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-xl bg-destructive/10 transition-colors group-hover:bg-destructive/15">
              <%= pb_icon(item[:icon], class_name: "h-5 w-5 text-destructive/70") %>
            </div>
            <h3 class="mb-2 text-base font-semibold text-foreground"><%= item[:title] %></h3>
            <p class="text-sm leading-relaxed text-muted-foreground"><%= item[:description] %></p>
          </article>
        <% end %>
      </div>
    </div>
  </section>

  <section id="how-it-works" class="bg-muted/30 py-24 md:py-32">
    <div class="mx-auto max-w-7xl px-6">
      <div class="mx-auto mb-16 max-w-2xl text-center" data-controller="reveal">
        <p class="mb-4 text-xs font-semibold uppercase tracking-widest text-primary">The Solution</p>
        <h2 class="text-3xl font-bold leading-tight tracking-tight text-foreground md:text-5xl">
          Everything organized. <span class="text-primary">Everything understood.</span>
        </h2>
      </div>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
        <% solutions.each_with_index do |item, index| %>
          <article class="relative rounded-2xl border border-border/50 bg-white p-8 shadow-sm transition-all duration-300 hover:shadow-md" data-controller="reveal" data-reveal-delay-value="<%= index * 90 %>">
            <div class="mb-5 flex items-center gap-4">
              <div class="flex h-12 w-12 items-center justify-center rounded-xl <%= item[:color] %>">
                <%= pb_icon(item[:icon], class_name: "h-6 w-6") %>
              </div>
              <span class="text-sm font-bold text-muted-foreground">0<%= index + 1 %></span>
            </div>
            <h3 class="mb-3 text-xl font-semibold text-foreground"><%= item[:title] %></h3>
            <p class="text-sm leading-relaxed text-muted-foreground"><%= item[:description] %></p>
          </article>
        <% end %>
      </div>
    </div>
  </section>

  <section id="features" class="bg-white py-24 md:py-32">
    <div class="mx-auto max-w-7xl px-6">
      <div class="mx-auto mb-16 max-w-2xl text-center" data-controller="reveal">
        <p class="mb-4 text-xs font-semibold uppercase tracking-widest text-primary">Features</p>
        <h2 class="text-3xl font-bold leading-tight tracking-tight text-foreground md:text-5xl">
          Everything you need, <span class="text-primary">nothing you don't.</span>
        </h2>
      </div>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
        <% feature_groups.each_with_index do |group, index| %>
          <article class="rounded-2xl border border-border/50 bg-muted/30 p-7 transition-all duration-300 hover:border-primary/20 <%= "md:col-span-2 lg:col-span-1" if index == 4 %>" data-controller="reveal" data-reveal-delay-value="<%= index * 70 %>">
            <h3 class="mb-1 text-lg font-semibold text-foreground"><%= group[:title] %></h3>
            <p class="mb-5 text-sm text-muted-foreground"><%= group[:subtitle] %></p>
            <div class="space-y-3">
              <% group[:items].each do |icon, label| %>
                <div class="flex items-center gap-3">
                  <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg border border-border/60 bg-white">
                    <%= pb_icon(icon, class_name: "h-4 w-4 text-primary/70") %>
                  </div>
                  <span class="text-sm text-foreground"><%= label %></span>
                </div>
              <% end %>
            </div>
          </article>
        <% end %>
      </div>
    </div>
  </section>

  <section class="bg-muted/30 py-24 md:py-32">
    <div class="mx-auto max-w-7xl px-6">
      <div class="mx-auto mb-16 max-w-2xl text-center" data-controller="reveal">
        <p class="mb-4 text-xs font-semibold uppercase tracking-widest text-primary">The Difference</p>
        <h2 class="text-3xl font-bold leading-tight tracking-tight text-foreground md:text-5xl">
          From chaos to <span class="text-primary">confidence.</span>
        </h2>
      </div>

      <div class="mx-auto grid max-w-4xl grid-cols-1 gap-6 md:grid-cols-2">
        <article class="rounded-2xl border border-border/50 bg-white p-8" data-controller="reveal">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full bg-destructive/10 px-3 py-1 text-xs font-medium text-destructive">Before PaperBridge</div>
          <div class="space-y-4">
            <% before_items.each do |item| %>
              <div class="flex items-center gap-3">
                <div class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-destructive/10">
                  <%= pb_icon("x", class_name: "h-3.5 w-3.5 text-destructive/70") %>
                </div>
                <span class="text-sm text-muted-foreground"><%= item %></span>
              </div>
            <% end %>
          </div>
        </article>

        <article class="rounded-2xl border border-primary/20 bg-white p-8 shadow-sm" data-controller="reveal" data-reveal-delay-value="90">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full bg-accent/30 px-3 py-1 text-xs font-medium text-foreground">After PaperBridge</div>
          <div class="space-y-4">
            <% after_items.each do |item| %>
              <div class="flex items-center gap-3">
                <div class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-accent/30">
                  <%= pb_icon("check", class_name: "h-3.5 w-3.5 text-primary") %>
                </div>
                <span class="text-sm font-medium text-foreground"><%= item %></span>
              </div>
            <% end %>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section id="care-team" class="bg-white py-24 md:py-32">
    <div class="mx-auto max-w-7xl px-6">
      <div class="grid grid-cols-1 items-center gap-16 lg:grid-cols-2">
        <div data-controller="reveal">
          <p class="mb-4 text-xs font-semibold uppercase tracking-widest text-primary">Care Team</p>
          <h2 class="mb-5 text-3xl font-bold leading-tight tracking-tight text-foreground md:text-4xl">
            Share the right information with the <span class="text-primary">right people.</span>
          </h2>
          <p class="mb-8 text-base leading-relaxed text-muted-foreground">
            Parents control who sees what. Invite care team members and grant category-based, read-only access to documents and summaries.
          </p>

          <div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
            <% roles.each_with_index do |(icon, label, color), index| %>
              <div class="flex items-center gap-2.5 rounded-xl bg-muted/40 p-3" data-controller="reveal" data-reveal-delay-value="<%= index * 45 %>">
                <div class="flex h-8 w-8 items-center justify-center rounded-lg <%= color %>">
                  <%= pb_icon(icon, class_name: "h-4 w-4") %>
                </div>
                <span class="text-sm font-medium text-foreground"><%= label %></span>
              </div>
            <% end %>
          </div>
        </div>

        <div class="rounded-2xl border border-border/60 bg-white p-6 shadow-lg" data-controller="reveal" data-reveal-delay-value="120">
          <div class="mb-6 flex items-center gap-3 border-b border-border/50 pb-4">
            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-primary/10">
              <%= pb_icon("graduation-cap", class_name: "h-5 w-5 text-primary") %>
            </div>
            <div>
              <p class="text-sm font-semibold text-foreground">Ms. Sarah Chen</p>
              <p class="text-xs text-muted-foreground">Teacher &middot; Maplewood Elementary</p>
            </div>
            <div class="ml-auto rounded-full bg-accent/30 px-2 py-0.5 text-[10px] font-medium text-foreground">Read-only</div>
          </div>

          <p class="mb-4 text-xs font-semibold uppercase tracking-wider text-muted-foreground">Document Access</p>
          <div class="space-y-3">
            <% permissions.each do |label, on| %>
              <div class="flex items-center justify-between py-2">
                <span class="text-sm text-foreground"><%= label %> Documents</span>
                <div class="flex h-6 w-10 items-center rounded-full px-0.5 transition-colors <%= on ? "justify-end bg-primary" : "justify-start bg-muted" %>">
                  <div class="h-5 w-5 rounded-full bg-white shadow-sm"></div>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-muted/30 py-24 md:py-32">
    <div class="mx-auto max-w-7xl px-6">
      <div class="mx-auto mb-16 max-w-2xl text-center" data-controller="reveal">
        <p class="mb-4 text-xs font-semibold uppercase tracking-widest text-primary">Advocacy Copilot</p>
        <h2 class="mb-5 text-3xl font-bold leading-tight tracking-tight text-foreground md:text-5xl">
          From paperwork to <span class="text-primary">action.</span>
        </h2>
        <p class="text-base leading-relaxed text-muted-foreground">
          PaperBridge does more than store documents. It helps parents prepare for meetings and understand what to do next.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-5 md:grid-cols-2 lg:grid-cols-3">
        <% advocacy_cards.each_with_index do |card, index| %>
          <article class="rounded-2xl border border-border/50 bg-white p-7 transition-all duration-300 hover:border-primary/20 hover:shadow-sm" data-controller="reveal" data-reveal-delay-value="<%= index * 70 %>">
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-xl bg-primary/10">
              <%= pb_icon(card[:icon], class_name: "h-5 w-5 text-primary") %>
            </div>
            <h3 class="mb-2 text-base font-semibold text-foreground"><%= card[:title] %></h3>
            <p class="text-sm leading-relaxed text-muted-foreground"><%= card[:description] %></p>
          </article>
        <% end %>
      </div>
    </div>
  </section>

  <section id="privacy" class="bg-white py-24 md:py-32">
    <div class="mx-auto max-w-7xl px-6">
      <div class="grid grid-cols-1 items-center gap-16 lg:grid-cols-2">
        <div data-controller="reveal">
          <p class="mb-4 text-xs font-semibold uppercase tracking-widest text-primary">Trust and Privacy</p>
          <h2 class="mb-5 text-3xl font-bold leading-tight tracking-tight text-foreground md:text-4xl">
            Built around your child's story. <span class="text-primary">Protected by design.</span>
          </h2>
          <p class="text-base leading-relaxed text-muted-foreground">
            PaperBridge is designed with your family's privacy at the center. You control every aspect of how information is organized and shared.
          </p>
        </div>

        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          <% privacy_items.each_with_index do |item, index| %>
            <article class="rounded-2xl border border-border/50 bg-muted/40 p-5" data-controller="reveal" data-reveal-delay-value="<%= index * 70 %>">
              <div class="mb-3 flex h-9 w-9 items-center justify-center rounded-xl bg-primary/10">
                <%= pb_icon(item[:icon], class_name: "h-4 w-4 text-primary") %>
              </div>
              <h3 class="mb-1.5 text-sm font-semibold text-foreground"><%= item[:title] %></h3>
              <p class="text-xs leading-relaxed text-muted-foreground"><%= item[:description] %></p>
            </article>
          <% end %>
        </div>
      </div>
    </div>
  </section>

  <section class="relative overflow-hidden bg-primary py-24 md:py-32">
    <div class="relative mx-auto max-w-3xl px-6 text-center" data-controller="reveal">
      <h2 class="mb-5 text-3xl font-bold leading-tight tracking-tight text-white md:text-5xl">Organize. Understand. Advocate.</h2>
      <p class="mx-auto mb-8 max-w-xl text-lg leading-relaxed text-white/70">
        PaperBridge gives families one place to manage documents, understand care information, and advocate with confidence.
      </p>
      <%= link_to primary_path, class: "inline-flex h-12 items-center justify-center rounded-full bg-white px-8 text-sm font-semibold text-primary shadow-lg transition-colors hover:bg-white/90" do %>
        Start with PaperBridge
        <%= pb_icon("arrow-right", class_name: "ml-2 h-4 w-4") %>
      <% end %>
    </div>
  </section>

  <footer class="border-t border-border/50 bg-white py-12">
    <div class="mx-auto max-w-7xl px-6">
      <div class="flex flex-col items-center justify-between gap-6 md:flex-row">
        <div class="flex items-center gap-2.5">
          <div class="flex h-7 w-7 items-center justify-center rounded-lg bg-primary">
            <span class="text-xs font-bold text-white">P</span>
          </div>
          <span class="text-sm font-semibold text-foreground">PaperBridge</span>
        </div>

        <div class="flex items-center gap-6">
          <a href="#features" class="text-xs text-muted-foreground transition-colors hover:text-foreground">Features</a>
          <a href="#privacy" class="text-xs text-muted-foreground transition-colors hover:text-foreground">Privacy</a>
          <a href="#care-team" class="text-xs text-muted-foreground transition-colors hover:text-foreground">Care Team</a>
        </div>

        <p class="text-xs text-muted-foreground">&copy; <%= Time.current.year %> PaperBridge. All rights reserved.</p>
      </div>
    </div>
  </footer>
</main>
