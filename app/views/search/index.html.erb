<main class="mx-auto flex max-w-7xl flex-col gap-8 px-4 py-8 sm:px-6 lg:px-8">
  <header class="border-b border-slate-200 pb-6">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <h1 class="text-3xl font-semibold text-slate-950">Search</h1>
        <p class="mt-2 text-sm text-slate-600">Ask a question across indexed documents for this account.</p>
      </div>

      <%= link_to "Back to documents", documents_path, class: "text-sm font-medium text-slate-600 hover:text-slate-950" %>
    </div>

    <%= form_with url: search_path, method: :get, class: "mt-6 flex flex-col gap-3 sm:flex-row" do |form| %>
      <%= form.search_field :q, value: @query, placeholder: "Ask about documents", class: "block w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm text-slate-950 shadow-sm outline-none focus:border-emerald-600 focus:ring-2 focus:ring-emerald-100" %>
      <%= form.submit "Search", class: "rounded-md bg-emerald-700 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-800" %>
    <% end %>
  </header>

  <% if @search_error.present? %>
    <section class="rounded-lg border border-red-200 bg-red-50 p-4 text-sm text-red-900">
      <p class="font-semibold">Search failed</p>
      <p class="mt-1"><%= @search_error %></p>
    </section>
  <% end %>

  <% if @query.present? %>
    <section class="space-y-4">
      <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <h2 class="text-xl font-semibold text-slate-950">Answer</h2>
          <p class="mt-1 text-sm text-slate-600">
            <%= pluralize(@results.count, "evidence chunk") %>
            across <%= @access_profile.allowed_chunk_labels.to_sentence %> labels.
          </p>
        </div>

        <% if @pipeline_run %>
          <p class="text-xs font-medium text-slate-500">Pipeline run #<%= @pipeline_run.id %></p>
        <% end %>
      </div>

      <% if @results.any? %>
        <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_24rem]">
          <section class="rounded-lg border border-slate-200 bg-white shadow-sm">
            <div class="border-b border-slate-100 px-5 py-4">
              <p class="text-xs font-semibold uppercase text-slate-500">Question</p>
              <h3 class="mt-1 text-base font-semibold text-slate-950"><%= @query %></h3>
            </div>

            <div class="space-y-6 px-5 py-5">
              <% if @answer.present? %>
                <div class="text-sm leading-7 text-slate-800">
                  <%= simple_format(@answer[:answer]) %>
                </div>

                <% if Array(@answer[:citations]).any? %>
                  <div>
                    <h4 class="text-sm font-semibold text-slate-950">Citations</h4>
                    <ul class="mt-3 space-y-3">
                      <% Array(@answer[:citations]).each do |citation| %>
                        <li class="rounded-md border border-slate-200 bg-slate-50 px-3 py-2 text-sm text-slate-700">
                          <p class="font-medium text-slate-950">
                            <%= citation[:document_title] %>, page <%= citation[:page_number] %>
                          </p>
                          <p class="mt-1 text-xs font-medium uppercase text-slate-500">
                            Chunk <%= citation[:chunk_id] %>
                          </p>
                          <% if citation[:quote].present? %>
                            <p class="mt-2 leading-6"><%= citation[:quote] %></p>
                          <% end %>
                        </li>
                      <% end %>
                    </ul>
                  </div>
                <% end %>

                <% if Array(@answer[:limitations]).any? %>
                  <div class="rounded-md border border-amber-200 bg-amber-50 px-3 py-2 text-sm text-amber-900">
                    <h4 class="font-semibold">Limitations</h4>
                    <ul class="mt-2 list-disc space-y-1 pl-5">
                      <% Array(@answer[:limitations]).each do |limitation| %>
                        <li><%= limitation %></li>
                      <% end %>
                    </ul>
                  </div>
                <% end %>
              <% else %>
                <p class="text-sm text-slate-600">No answer was generated for this search.</p>
              <% end %>
            </div>
          </section>

          <aside class="space-y-4">
            <div>
              <h3 class="text-base font-semibold text-slate-950">Evidence</h3>
              <p class="mt-1 text-sm text-slate-600">Retrieved chunks used as answer context.</p>
            </div>

            <div class="space-y-3">
              <% @results.each do |result| %>
                <article class="rounded-lg border border-slate-200 bg-white shadow-sm">
                  <header class="border-b border-slate-100 px-4 py-3">
                    <h4 class="truncate text-sm font-semibold text-slate-950">
                      <%= link_to result.document.title, document_path(result.document), class: "hover:text-emerald-800" %>
                    </h4>
                    <p class="mt-1 text-xs font-medium uppercase text-slate-500">
                      <%= result.chunk.label.humanize %> chunk <%= result.chunk.chunk_index %> &middot; page <%= result.page.page_number %>
                    </p>
                    <div class="mt-3 flex flex-wrap gap-2">
                      <span class="inline-flex rounded-md bg-slate-100 px-2.5 py-1 text-xs font-semibold text-slate-700">
                        Similarity <%= number_to_percentage(result.similarity * 100, precision: 1) %>
                      </span>
                      <span class="inline-flex rounded-md bg-slate-100 px-2.5 py-1 text-xs font-semibold text-slate-700">
                        Distance <%= number_with_precision(result.distance, precision: 4) %>
                      </span>
                    </div>
                  </header>

                  <pre class="max-h-64 overflow-auto whitespace-pre-wrap break-words px-4 py-3 text-xs leading-5 text-slate-800"><%= result.chunk.content %></pre>
                </article>
              <% end %>
            </div>
          </aside>
        </div>
      <% else %>
        <div class="rounded-lg border border-dashed border-slate-300 bg-white px-4 py-10 text-center">
          <p class="text-sm font-medium text-slate-700">No matching chunks found.</p>
          <p class="mt-1 text-sm text-slate-500">Try another query or upload documents with processed embeddings.</p>
        </div>
      <% end %>
    </section>
  <% else %>
    <section class="rounded-lg border border-dashed border-slate-300 bg-white px-4 py-12 text-center">
      <h2 class="text-base font-semibold text-slate-950">Enter a search query</h2>
      <p class="mt-1 text-sm text-slate-500">Results will be limited to chunks available to your role.</p>
    </section>
  <% end %>
</main>
