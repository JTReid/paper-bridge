<main class="mx-auto flex max-w-7xl flex-col gap-8 px-4 py-8 sm:px-6 lg:px-8">
  <header class="border-b border-slate-200 pb-6">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <h1 class="text-3xl font-semibold text-slate-950">Search</h1>
        <p class="mt-2 text-sm text-slate-600">Search indexed document chunks for this account.</p>
      </div>

      <%= link_to "Back to documents", documents_path, class: "text-sm font-medium text-slate-600 hover:text-slate-950" %>
    </div>

    <%= form_with url: search_path, method: :get, class: "mt-6 flex flex-col gap-3 sm:flex-row" do |form| %>
      <%= form.search_field :q, value: @query, placeholder: "Search documents", class: "block w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm text-slate-950 shadow-sm outline-none focus:border-emerald-600 focus:ring-2 focus:ring-emerald-100" %>
      <%= form.submit "Search", class: "rounded-md bg-emerald-700 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-800" %>
    <% end %>
  </header>

  <% if @search_error.present? %>
    <section class="rounded-lg border border-red-200 bg-red-50 p-4 text-sm text-red-900">
      <p class="font-semibold">Search failed</p>
      <p class="mt-1"><%= @search_error %></p>
    </section>
  <% end %>

  <% if @query.present? %>
    <section class="space-y-4">
      <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <h2 class="text-xl font-semibold text-slate-950">Results</h2>
          <p class="mt-1 text-sm text-slate-600">
            <%= pluralize(@results.count, "matching chunk") %>
            across <%= @access_profile.allowed_chunk_labels.to_sentence %> labels.
          </p>
        </div>

        <% if @pipeline_run %>
          <p class="text-xs font-medium text-slate-500">Pipeline run #<%= @pipeline_run.id %></p>
        <% end %>
      </div>

      <% if @results.any? %>
        <div class="space-y-4">
          <% @results.each do |result| %>
            <article class="rounded-lg border border-slate-200 bg-white shadow-sm">
              <header class="flex flex-col gap-3 border-b border-slate-100 px-4 py-3 lg:flex-row lg:items-center lg:justify-between">
                <div class="min-w-0">
                  <h3 class="truncate text-sm font-semibold text-slate-950">
                    <%= link_to result.document.title, document_path(result.document), class: "hover:text-emerald-800" %>
                  </h3>
                  <p class="mt-1 text-xs font-medium uppercase text-slate-500">
                    <%= result.chunk.label.humanize %> chunk <%= result.chunk.chunk_index %> &middot; page <%= result.page.page_number %>
                  </p>
                </div>

                <div class="flex flex-wrap gap-2">
                  <span class="inline-flex rounded-md bg-slate-100 px-2.5 py-1 text-xs font-semibold text-slate-700">
                    Similarity <%= number_to_percentage(result.similarity * 100, precision: 1) %>
                  </span>
                  <span class="inline-flex rounded-md bg-slate-100 px-2.5 py-1 text-xs font-semibold text-slate-700">
                    Distance <%= number_with_precision(result.distance, precision: 4) %>
                  </span>
                </div>
              </header>

              <pre class="max-h-72 overflow-auto whitespace-pre-wrap break-words px-4 py-4 text-sm leading-6 text-slate-800"><%= result.chunk.content %></pre>
            </article>
          <% end %>
        </div>
      <% else %>
        <div class="rounded-lg border border-dashed border-slate-300 bg-white px-4 py-10 text-center">
          <p class="text-sm font-medium text-slate-700">No matching chunks found.</p>
          <p class="mt-1 text-sm text-slate-500">Try another query or upload documents with processed embeddings.</p>
        </div>
      <% end %>
    </section>
  <% else %>
    <section class="rounded-lg border border-dashed border-slate-300 bg-white px-4 py-12 text-center">
      <h2 class="text-base font-semibold text-slate-950">Enter a search query</h2>
      <p class="mt-1 text-sm text-slate-500">Results will be limited to chunks available to your role.</p>
    </section>
  <% end %>
</main>
