<main class="mx-auto max-w-3xl px-4 py-8 sm:px-6 lg:px-8">
  <nav>
    <%= link_to documents_path, class: "inline-flex items-center text-sm font-medium text-slate-600 hover:text-slate-950" do %>
      <span aria-hidden="true" class="mr-2">&larr;</span>
      Back to documents
    <% end %>
  </nav>

  <header class="mt-8 border-b border-slate-200 pb-6">
    <h1 class="text-3xl font-semibold text-slate-950">Upload Document</h1>
  </header>

  <section class="mt-8">
    <%= render "form", document: @document %>
  </section>
</main>
