<% content_for :title, "Documents | PaperBridge" %>

<%= app_shell(active: :documents, dependent: @dependent) do %>
  <div class="space-y-8">
    <header class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="mb-1 text-xs font-medium uppercase tracking-widest text-accent">Care Records</p>
        <h1 class="text-2xl font-bold tracking-tight text-primary md:text-3xl"><%= @dependent ? "#{@dependent.name}'s Documents" : "Documents" %></h1>
        <p class="mt-1.5 text-sm text-muted-foreground">All records organized by user and ready to search.</p>
      </div>
      <div class="flex flex-col gap-2 sm:flex-row">
        <%= link_to dependent_ai_assistant_path(@dependent), class: "inline-flex h-10 items-center justify-center rounded-full border border-accent text-primary px-4 text-xs font-medium transition-colors hover:bg-accent/10" do %>
          <%= pb_icon("sparkles", class_name: "mr-1.5 h-3.5 w-3.5") %>
          Ask AI
        <% end %>
        <%= link_to new_dependent_document_path(@dependent), class: "inline-flex h-10 items-center justify-center rounded-full bg-accent px-5 text-sm font-medium text-accent-foreground shadow-sm transition-all duration-200 hover:bg-accent/80" do %>
          <%= pb_icon("upload", class_name: "mr-1.5 h-4 w-4") %>
          Add Documents
        <% end %>
      </div>
    </header>

    <section class="grid grid-cols-1 gap-4 sm:grid-cols-3">
      <article class="rounded-2xl border border-border/60 bg-white p-5 shadow-sm">
        <p class="text-xs text-muted-foreground">Total records</p>
        <p class="mt-1 text-2xl font-bold text-primary"><%= @documents.count %></p>
      </article>
      <article class="rounded-2xl border border-border/60 bg-white p-5 shadow-sm">
        <p class="text-xs text-muted-foreground">Processed</p>
        <p class="mt-1 text-2xl font-bold text-primary"><%= @processed_count %></p>
      </article>
      <article class="rounded-2xl border border-border/60 bg-white p-5 shadow-sm">
        <p class="text-xs text-muted-foreground">In progress</p>
        <p class="mt-1 text-2xl font-bold text-primary"><%= @processing_count %></p>
      </article>
    </section>

    <section class="flex flex-col gap-3 sm:flex-row">
      <%= form_with url: dependent_ai_assistant_path(@dependent), method: :get, class: "relative flex-1" do |form| %>
        <%= pb_icon("search", class_name: "pointer-events-none absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-muted-foreground") %>
        <%= form.search_field :q, placeholder: "Search documents with AI...", class: "h-10 w-full rounded-xl border border-border bg-white pl-9 pr-3 text-sm text-foreground outline-none transition-colors focus:border-primary focus:ring-2 focus:ring-primary/10" %>
      <% end %>
      <div class="inline-flex h-10 items-center rounded-xl border border-border bg-white px-3 text-sm text-muted-foreground">
        All Categories
      </div>
    </section>

    <% if @documents.any? %>
      <section class="overflow-hidden rounded-2xl border border-border/60 bg-white shadow-sm">
        <div class="divide-y divide-border/40">
          <% @documents.each do |document| %>
            <% label = document.document_chunks.first&.label || "general" %>
            <% label_class = case label
              when "medical" then "bg-red-50 text-red-600"
              when "education" then "bg-blue-50 text-blue-700"
              when "therapy" then "bg-green-50 text-green-700"
              when "legal" then "bg-violet-50 text-violet-700"
              when "financial" then "bg-amber-50 text-amber-700"
              else "bg-muted text-muted-foreground"
            end %>
            <%= link_to document_path(document), class: "group flex items-center gap-4 px-5 py-4 transition-colors hover:bg-muted/20" do %>
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-muted transition-colors group-hover:bg-primary/5">
                <%= pb_icon("file-text", class_name: "h-4 w-4 text-muted-foreground") %>
              </div>
              <div class="min-w-0 flex-1">
                <p class="truncate text-sm font-semibold text-foreground"><%= document.title %></p>
                <p class="mt-0.5 truncate text-xs text-muted-foreground">
                  <%= document.original_filename.presence || "Attached file" %>
                  <span class="ml-2 text-muted-foreground/70">&middot; <%= document.dependent.name %></span>
                  <span class="ml-2 text-muted-foreground/70">&middot; <%= l document.created_at, format: :short %></span>
                </p>
              </div>
              <span class="hidden rounded-full border-0 px-2 py-0.5 text-[10px] font-medium sm:inline-flex <%= label_class %>">
                <%= document.category.humanize %>
              </span>
              <span class="rounded-full border-0 px-2 py-0.5 text-[10px] font-medium <%= document.processed? ? "bg-green-50 text-green-700" : document.failed? ? "bg-red-50 text-red-500" : "bg-blue-50 text-blue-600" %>">
                <%= document.status.humanize %>
              </span>
            <% end %>
          <% end %>
        </div>
      </section>
    <% else %>
      <section class="rounded-2xl border border-border/60 bg-white p-8 shadow-sm">
        <div class="mx-auto max-w-xl text-center">
          <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-2xl border border-primary/10 bg-primary/5">
            <%= pb_icon("file-text", class_name: "h-5 w-5 text-primary/50") %>
          </div>
          <h2 class="text-base font-semibold text-foreground">Start by adding your first document</h2>
          <p class="mt-2 text-sm leading-relaxed text-muted-foreground">Upload school reports, medical notes, therapy summaries, or insurance documents in one secure place.</p>
          <%= link_to "Add First Document", new_dependent_document_path(@dependent), class: "mt-5 inline-flex rounded-full bg-primary px-5 py-2 text-xs font-medium text-white transition-colors hover:bg-primary/90" %>
        </div>
      </section>
    <% end %>
  </div>
<% end %>
