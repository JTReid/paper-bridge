<aside id="<%= dom_id(document, :file_details) %>" class="h-fit rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
  <h2 class="text-sm font-semibold uppercase text-slate-500">File Details</h2>

  <dl class="mt-4 divide-y divide-slate-100 text-sm">
    <div class="py-3">
      <dt class="font-medium text-slate-500">Original filename</dt>
      <dd class="mt-1 break-words text-slate-950"><%= document.original_filename %></dd>
    </div>

    <div class="py-3">
      <dt class="font-medium text-slate-500">Content type</dt>
      <dd class="mt-1 break-words text-slate-950"><%= document.content_type %></dd>
    </div>

    <div class="py-3">
      <dt class="font-medium text-slate-500">Uploaded</dt>
      <dd class="mt-1 text-slate-950"><%= l document.created_at, format: :long %></dd>
    </div>

    <div class="py-3">
      <dt class="font-medium text-slate-500">Last updated</dt>
      <dd class="mt-1 text-slate-950"><%= l document.updated_at, format: :long %></dd>
    </div>
  </dl>
</aside>
