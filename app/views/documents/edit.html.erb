<% content_for :title, "Edit Document | PaperBridge" %>

<%= app_shell(active: :documents, dependent: @dependent) do %>
  <div class="mx-auto max-w-3xl space-y-8">
    <nav>
      <%= link_to document_path(@document), class: "inline-flex items-center text-sm font-medium text-slate-600 hover:text-slate-950" do %>
        <span aria-hidden="true" class="mr-2">&larr;</span>
        Back to document
      <% end %>
    </nav>

    <header class="border-b border-slate-200 pb-6">
      <p class="mb-1 text-xs font-medium uppercase tracking-widest text-accent">Care Records</p>
      <h1 class="text-3xl font-semibold text-slate-950">Edit Document</h1>
      <p class="mt-2 text-sm text-slate-600">Update the document title, description, or category.</p>
    </header>

    <%= render "form", document: @document %>
  </div>
<% end %>
