<div id="<%= dom_id(document, :processing_stats) %>" class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
  <% document_processing_stats(document).each do |stat| %>
    <div class="rounded-lg border border-slate-200 bg-white p-4 shadow-sm" data-testid="document-processing-stat-<%= stat[:label].parameterize %>">
      <div class="flex min-h-5 items-center justify-between gap-3">
        <p class="text-xs font-semibold uppercase text-slate-500"><%= stat[:label] %></p>
        <%= processing_stat_indicator(stat[:state], label: stat[:label]) %>
      </div>

      <p class="mt-2 text-2xl font-semibold text-slate-950"><%= stat[:value] %></p>
    </div>
  <% end %>
</div>
