<%
  dependent_context = dependent.present?
  account_name = current_account&.name || "PaperBridge"
  actor_label = current_user.name.presence || current_user.email

  if dependent_context
    dependent_initials = dependent.name.to_s.split.map { |word| word.first }.join.first(2).presence || "U"
    dependent_meta = [dependent.grade, dependent.school].compact_blank.join(" - ")
    nav_items = [
      { key: :overview, label: "Overview", path: dependent_path(dependent), icon: "user-circle" },
      { key: :documents, label: "Documents", path: dependent_documents_path(dependent), icon: "file-text" },
      { key: :ai_assistant, label: "AI Assistant", path: dependent_ai_assistant_path(dependent), icon: "brain" },
      { key: :care_team, label: "Care Team", path: dependent_care_team_memberships_path(dependent), icon: "users" }
    ]
  else
    nav_items = [
      { key: :dashboard, label: "Dashboard", path: dashboard_path, icon: "sparkles" },
      { key: :dependents, label: "Users", path: dependents_path, icon: "users" }
    ]
  end
%>

<main class="min-h-screen bg-background text-foreground lg:flex">
  <aside class="hidden min-h-screen w-[248px] shrink-0 border-r border-border/50 bg-white lg:flex lg:flex-col">
    <% if dependent_context %>
      <div class="border-b border-border/40 px-4 py-6">
        <%= link_to dashboard_path, class: "inline-flex items-center gap-2 text-sm font-medium text-muted-foreground transition-colors hover:text-foreground" do %>
          <%= pb_icon("arrow-left", class_name: "h-4 w-4") %>
          All Profiles
        <% end %>

        <div class="mt-5 flex items-center gap-3">
          <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-primary/10 text-sm font-bold text-primary">
            <%= dependent_initials %>
          </div>
          <div class="min-w-0">
            <p class="truncate text-sm font-bold text-foreground"><%= dependent.name %></p>
            <% if dependent_meta.present? %>
              <p class="mt-0.5 truncate text-xs text-muted-foreground"><%= dependent_meta %></p>
            <% end %>
          </div>
        </div>
      </div>
    <% else %>
      <div class="border-b border-border/40 p-5">
        <%= link_to root_path, class: "block", aria: { label: "PaperBridge home" } do %>
          <%= paperbridge_logo(width: 156, height: 54, class_name: "h-[54px] w-[156px]") %>
        <% end %>
      </div>
    <% end %>

    <nav class="flex-1 space-y-1 px-3 py-4">
      <% nav_items.each do |item| %>
        <% active_item = active == item[:key] %>
        <%= link_to item[:path], class: "flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm font-medium transition-all duration-150 #{active_item ? "bg-primary text-white shadow-sm" : "text-muted-foreground hover:bg-muted/60 hover:text-foreground"}" do %>
          <%= pb_icon(item[:icon], class_name: "h-4 w-4 shrink-0") %>
          <span><%= item[:label] %></span>
        <% end %>
      <% end %>
    </nav>

    <div class="border-t border-border/40 p-4">
      <p class="text-[10px] uppercase tracking-wider text-muted-foreground">Workspace</p>
      <p class="mt-1 truncate text-sm font-semibold text-foreground"><%= account_name %></p>
      <p class="mt-1 truncate text-xs text-muted-foreground"><%= actor_label %></p>
      <%= button_to destroy_user_session_path,
          method: :delete,
          class: "mt-4 flex w-full items-center justify-center rounded-xl border border-border bg-white px-3 py-2 text-sm font-medium text-muted-foreground transition-colors hover:bg-muted/60 hover:text-foreground" do %>
        Log Out
      <% end %>
    </div>
  </aside>

  <div class="min-w-0 flex-1">
    <header class="sticky top-0 z-40 border-b border-border/50 bg-white/85 backdrop-blur-xl lg:hidden">
      <div class="flex h-16 items-center justify-between px-5">
        <%= link_to(dependent_context ? dashboard_path : root_path, class: "flex items-center", aria: { label: "PaperBridge home" }) do %>
          <%= paperbridge_logo(width: 140, height: 50, class_name: "h-[50px] w-[140px]") %>
        <% end %>
        <details class="group">
          <summary class="flex h-10 w-10 cursor-pointer list-none items-center justify-center rounded-full text-foreground transition-colors hover:bg-muted [&::-webkit-details-marker]:hidden">
            <%= pb_icon("menu", class_name: "h-5 w-5") %>
          </summary>
          <div class="absolute left-0 right-0 top-16 border-b border-border bg-white px-5 py-4 shadow-sm">
            <% if dependent_context %>
              <div class="mb-4 border-b border-border/50 pb-4">
                <%= link_to dashboard_path, class: "mb-4 inline-flex items-center gap-2 text-sm font-medium text-muted-foreground hover:text-foreground" do %>
                  <%= pb_icon("arrow-left", class_name: "h-4 w-4") %>
                  All Profiles
                <% end %>
                <div class="flex items-center gap-3">
                  <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-2xl bg-primary/10 text-sm font-bold text-primary">
                    <%= dependent_initials %>
                  </div>
                  <div class="min-w-0">
                    <p class="truncate text-sm font-bold text-foreground"><%= dependent.name %></p>
                    <% if dependent_meta.present? %>
                      <p class="mt-0.5 truncate text-xs text-muted-foreground"><%= dependent_meta %></p>
                    <% end %>
                  </div>
                </div>
              </div>
            <% end %>

            <div class="space-y-2">
              <% nav_items.each do |item| %>
                <% active_item = active == item[:key] %>
                <%= link_to item[:path], class: "flex items-center gap-3 rounded-xl px-3 py-2 text-sm font-medium #{active_item ? "bg-primary text-white" : "text-muted-foreground hover:bg-muted"}" do %>
                  <%= pb_icon(item[:icon], class_name: "h-4 w-4") %>
                  <%= item[:label] %>
                <% end %>
              <% end %>
            </div>

            <div class="mt-4 border-t border-border/50 pt-4">
              <%= button_to destroy_user_session_path,
                  method: :delete,
                  class: "flex w-full items-center justify-center rounded-xl border border-border bg-white px-3 py-2 text-sm font-medium text-muted-foreground hover:bg-muted hover:text-foreground" do %>
                Log Out
              <% end %>
            </div>
          </div>
        </details>
      </div>
    </header>

    <section class="mx-auto max-w-6xl px-5 py-8 sm:px-6 md:py-10 lg:px-8">
      <%= content %>
    </section>
  </div>
</main>
